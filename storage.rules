rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Verification documents — write-only for authenticated users
    // Reads go through getVerificationDocument cloud function (checks family ownership)
    match /verification-documents/{familyId}/{allPaths=**} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // Profile photos — authenticated users can upload/read
    match /profile-photos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Family photos — authenticated users can upload/read
    match /family-photos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

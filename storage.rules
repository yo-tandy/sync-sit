rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Verification documents — authenticated users can upload/read
    // Family ownership enforced at the application level (cloud functions validate)
    match /verification-documents/{familyId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Profile photos — only the owner can write their own photo
    // App uses path: profile-photos/{uid}.{ext}
    match /profile-photos/{fileName} {
      allow read: if request.auth != null;
      // fileName starts with the user's UID (e.g. "abc123.jpg")
      allow write: if request.auth != null
                   && fileName[0:request.auth.uid.size()] == request.auth.uid;
    }

    // Family photos — authenticated users can upload/read
    // Family ownership enforced at the application level
    match /family-photos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

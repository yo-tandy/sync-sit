rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if the requester is the document owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: the requester's own user document data.
    function callerData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Plan D dual-read helpers — tolerate BOTH the legacy flat shape
    // (top-level `role`/`familyId`) and the new shape (`profiles.{role}`,
    // `isAdmin`). `.get(key, default)` avoids errors when a field is absent
    // in one of the two shapes.

    // Helper: check if the requester is an admin
    function isAdmin() {
      return isAuth()
             && (callerData().get('role', '') == 'admin'
                 || callerData().get('isAdmin', false) == true);
    }

    // Helper: is the given user-doc data a babysitter (either shape)?
    function isBabysitterData(d) {
      return d.get('role', '') == 'babysitter'
             || d.get('profiles', {}).get('babysitter', null) != null;
    }

    // Helper: the parent familyId on a user-doc data map, or null if the
    // user is not a parent. New shape: profiles.parent.familyId; legacy: the
    // top-level familyId when role == 'parent'.
    function parentFamilyId(d) {
      return d.get('profiles', {}).get('parent', {}).get('familyId',
               d.get('role', '') == 'parent' ? d.get('familyId', null) : null);
    }

    // Helper: the set of profile-role keys a user-doc holds (babysitter,
    // parent, tutor). Owners may edit fields WITHIN their profiles, but may
    // not add or remove a role slot — that is a privilege escalation (e.g. a
    // parent granting themselves a searchable babysitter profile). Under Plan
    // D this replaces the old top-level `role` blocklist entry.
    function profileRolesUnchanged() {
      return request.resource.data.get('profiles', {}).keys()
               .hasOnly(resource.data.get('profiles', {}).keys())
             && resource.data.get('profiles', {}).keys()
               .hasOnly(request.resource.data.get('profiles', {}).keys());
    }

    // Helper: a babysitter-profile field on a user-doc data map (safe default).
    function bsField(d, key, def) {
      return d.get('profiles', {}).get('babysitter', {}).get(key, def);
    }

    // Helper: server-owned identity fields inside profiles.babysitter that the
    // client must never mutate directly.
    // - ejemEmail: EJM identity, set by enrollBabysitter only.
    // - approvedFamilies: contact-sharing audit trail. respondToContactSharing
    //   writes auditLog entries on every change; allowing direct client writes
    //   would bypass that audit point and the GDPR-required record of which
    //   families a babysitter has shared contact with.
    function babysitterIdentityUnchanged() {
      return bsField(request.resource.data, 'ejemEmail', '')
               == bsField(resource.data, 'ejemEmail', '')
             && bsField(request.resource.data, 'approvedFamilies', [])
               == bsField(resource.data, 'approvedFamilies', []);
    }

    // Helper: profiles.parent.familyId is server-controlled (enrollFamily /
    // joinFamily). A client must not move themselves between families.
    function parentFamilyIdUnchanged() {
      return request.resource.data.get('profiles', {}).get('parent', {}).get('familyId', '')
               == resource.data.get('profiles', {}).get('parent', {}).get('familyId', '');
    }

    // Helper: check if the requester is a member of a family
    function isFamilyMember(familyId) {
      return isAuth() && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.parentIds;
    }

    // Users: read own profile; parents can read active babysitters (for search results)
    match /users/{userId} {
      allow read: if isOwner(userId)
                  || isAdmin()
                  || (isAuth() && isBabysitterData(resource.data) && resource.data.status == 'active')
                  || (isAuth() && parentFamilyId(resource.data) != null
                      && parentFamilyId(resource.data) == parentFamilyId(callerData()));
      allow create, delete: if false; // Only via Cloud Functions
      // Owner-update guards (Plan D, profiles.{role} shape):
      // - Top-level identity/admin fields must never change client-side:
      //   * uid/email/status/createdAt: identity; `status` is the hard ban gate
      //     that admin's blockUser callable owns.
      //   * isAdmin: the new-shape admin-escalation vector.
      //   * role/ejemEmail/approvedFamilies: LEGACY top-level fields. They are
      //     gone after migration, but during the dual-read window a not-yet-
      //     migrated doc still carries them, and isAdmin() still honors a legacy
      //     `role == 'admin'`. Keep blocking them until the fallback is removed.
      // - profileRolesUnchanged: the SET of role slots can't change — blocks a
      //   client granting itself a new role (e.g. injecting profiles.babysitter).
      // - babysitterIdentityUnchanged / parentFamilyIdUnchanged: server-owned
      //   fields nested inside a profile the owner otherwise may edit.
      // NOTE: `profiles.babysitter.searchable` is intentionally editable — it
      //   is user-controlled by design (soft hide from search).
      allow update: if isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['uid', 'email', 'status', 'createdAt', 'isAdmin',
                                 'role', 'ejemEmail', 'approvedFamilies'])
                    && profileRolesUnchanged()
                    && babysitterIdentityUnchanged()
                    && parentFamilyIdUnchanged();
    }

    // Families: readable + editable by family members + admin
    match /families/{familyId} {
      allow read: if isFamilyMember(familyId) || isAdmin();
      allow create, delete: if false;
      // Field-level guard: family members can only edit profile fields from the
      // client. Sensitive state (verification.*, parentIds, preferredBabysitters,
      // searchDefaults, status) is mutated exclusively by callables via the
      // Admin SDK (which bypasses these rules).
      allow update: if isFamilyMember(familyId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['familyName', 'address', 'latLng', 'pets', 'note', 'photoUrl', 'updatedAt']);

      match /kids/{kidId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        allow write: if isFamilyMember(familyId);
      }
    }

    // Schedules: own schedule readable + writable by owner
    match /schedules/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /overrides/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Searches: readable by family members who created them
    match /searches/{searchId} {
      allow read: if isAuth() && isFamilyMember(resource.data.familyId);
      allow write: if false;
    }

    // Appointments: readable by involved babysitter or family
    match /appointments/{appointmentId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.babysitterUserId
        || isFamilyMember(resource.data.familyId)
        || isAdmin()
      );
      allow write: if false;
    }

    // References: readable by anyone authenticated (shown in search results)
    match /references/{referenceId} {
      allow read: if isAuth();
      // Create: babysitters may record their own offline manual references.
      // Parent endorsements (type='family_submitted') and admin/peer
      // approvals (type='manual' moving to status='approved'/'published')
      // are NOT writable from the client SDK — they go through the
      // submitFamilyEndorsement / acceptFamilyEndorsement /
      // publishManualReference callables, which validate the
      // submitter<->babysitter relationship and admin role server-side.
      // See agent-9-security-baseline.md §7 [BL-5] and [BL-6].
      allow create: if isAuth()
        && request.resource.data.status == 'private'
        && request.resource.data.babysitterUserId == request.auth.uid
        && request.resource.data.type == 'manual'
        && (!('submittedByUserId' in request.resource.data)
            || request.resource.data.submittedByUserId == null);
      // Update: owner (babysitter or submitter) may edit their own reference,
      // but cannot:
      //  - mutate the identity tuple (babysitterUserId, submittedByUserId,
      //    type, createdAt) — prevents transferring an endorsement between
      //    babysitters or laundering an identity post-create;
      //  - promote status to 'approved' or 'published' — kills the
      //    BLOCK-LATER-4 reference-count inflation vector via update path.
      //    Status may only transition to 'private' or 'removed' from the
      //    client. The babysitter's previous "publish my own manual reference"
      //    flow was the fraud vector itself; restoring controlled publish
      //    requires a callable with admin/peer-approval gating.
      allow update: if isAuth()
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['babysitterUserId', 'submittedByUserId', 'type', 'createdAt'])
        && (
          resource.data.babysitterUserId == request.auth.uid
          || (
            'submittedByUserId' in resource.data
            && resource.data.submittedByUserId != null
            && resource.data.submittedByUserId == request.auth.uid
          )
        )
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status'])
          || request.resource.data.status in ['private', 'removed']
        );
      allow delete: if false;
    }

    // Notifications: own only, can mark as read
    match /notifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == resource.data.recipientUserId;
      allow update: if isAuth()
                    && request.auth.uid == resource.data.recipientUserId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // Invite links: no client access (validated via validateInviteLink Cloud Function)
    match /inviteLinks/{token} {
      allow read, write: if false;
    }

    // Verification codes: no client access
    match /verificationCodes/{email} {
      allow read, write: if false;
    }

    // Holidays: readable by anyone authenticated
    match /holidays/{schoolYear} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Audit log: admin only
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Contact sharing requests: babysitter can read own, family members can read for their family
    match /contactSharingRequests/{requestId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.babysitterUserId
        || isFamilyMember(resource.data.familyId)
        || isAdmin()
      );
      allow create, update, delete: if false; // Only via Cloud Functions
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if the requester is the document owner
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: check if the requester is an admin
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if the requester is a member of a family
    function isFamilyMember(familyId) {
      return isAuth() && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.parentIds;
    }

    // Users: read own profile; parents can read active babysitters (for search results)
    match /users/{userId} {
      allow read: if isOwner(userId)
                  || isAdmin()
                  || (isAuth() && resource.data.role == 'babysitter' && resource.data.status == 'active')
                  || (isAuth() && resource.data.role == 'parent'
                      && resource.data.familyId != null
                      && resource.data.familyId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId);
      allow create, delete: if false; // Only via Cloud Functions
      // Owner-update blocklist:
      // - role/status/uid/email/ejemEmail/createdAt: identity + admin-controlled
      //   fields that must never change client-side.
      // - approvedFamilies: contact-sharing audit trail. respondToContactSharing
      //   writes auditLog entries on every change; allowing direct client writes
      //   would bypass that audit point and the GDPR-required record of which
      //   families a babysitter has shared contact with.
      // NOTE: `searchable` is intentionally NOT in this list — it is
      //   user-controlled by design (soft hide from search). The hard ban
      //   gate is the `status` field (already blocked above), which
      //   admin's blockUser callable owns.
      allow update: if isOwner(userId)
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role', 'status', 'uid', 'email', 'ejemEmail', 'createdAt',
                                 'approvedFamilies']);
    }

    // Families: readable + editable by family members + admin
    match /families/{familyId} {
      allow read: if isFamilyMember(familyId) || isAdmin();
      allow create, delete: if false;
      // Field-level guard: family members can only edit profile fields from the
      // client. Sensitive state (verification.*, parentIds, preferredBabysitters,
      // searchDefaults, status) is mutated exclusively by callables via the
      // Admin SDK (which bypasses these rules).
      allow update: if isFamilyMember(familyId)
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['familyName', 'address', 'latLng', 'pets', 'note', 'photoUrl', 'updatedAt']);

      match /kids/{kidId} {
        allow read: if isFamilyMember(familyId) || isAdmin();
        allow write: if isFamilyMember(familyId);
      }
    }

    // Schedules: own schedule readable + writable by owner
    match /schedules/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);

      match /overrides/{date} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Searches: readable by family members who created them
    match /searches/{searchId} {
      allow read: if isAuth() && isFamilyMember(resource.data.familyId);
      allow write: if false;
    }

    // Appointments: readable by involved babysitter or family
    match /appointments/{appointmentId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.babysitterUserId
        || isFamilyMember(resource.data.familyId)
        || isAdmin()
      );
      allow write: if false;
    }

    // References: readable by anyone authenticated (shown in search results)
    match /references/{referenceId} {
      allow read: if isAuth();
      // Create: force initial status='private' so newly-created references
      // never surface in searchBabysitters (which filters status in
      // ['approved','published']) without an explicit downstream transition.
      // Two legitimate branches:
      //  - Babysitter records their own offline reference (type='manual',
      //    no submitter — recording an out-of-band endorsement).
      //  - Parent endorses a different babysitter (type='family_submitted',
      //    submitter is the auth user, babysitter is someone else).
      // Self-puffery via the family_submitted branch (babysitter writing
      // about themselves) and submitter-impersonation as oneself
      // (submittedByUserId==babysitterUserId) are denied.
      allow create: if isAuth()
        && request.resource.data.status == 'private'
        && (
          (
            request.resource.data.babysitterUserId == request.auth.uid
            && request.resource.data.type == 'manual'
            && (!('submittedByUserId' in request.resource.data)
                || request.resource.data.submittedByUserId == null)
          )
          || (
            request.resource.data.submittedByUserId == request.auth.uid
            && request.resource.data.babysitterUserId != request.auth.uid
            && request.resource.data.type == 'family_submitted'
          )
        );
      allow update: if isAuth() && (
        resource.data.babysitterUserId == request.auth.uid
        || resource.data.submittedByUserId == request.auth.uid
      );
      allow delete: if false;
    }

    // Notifications: own only, can mark as read
    match /notifications/{notifId} {
      allow read: if isAuth() && request.auth.uid == resource.data.recipientUserId;
      allow update: if isAuth()
                    && request.auth.uid == resource.data.recipientUserId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create, delete: if false;
    }

    // Invite links: no client access (validated via validateInviteLink Cloud Function)
    match /inviteLinks/{token} {
      allow read, write: if false;
    }

    // Verification codes: no client access
    match /verificationCodes/{email} {
      allow read, write: if false;
    }

    // Holidays: readable by anyone authenticated
    match /holidays/{schoolYear} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Audit log: admin only
    match /auditLog/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Contact sharing requests: babysitter can read own, family members can read for their family
    match /contactSharingRequests/{requestId} {
      allow read: if isAuth() && (
        request.auth.uid == resource.data.babysitterUserId
        || isFamilyMember(resource.data.familyId)
        || isAdmin()
      );
      allow create, update, delete: if false; // Only via Cloud Functions
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
